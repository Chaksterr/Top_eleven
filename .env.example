# ============================================================================
# Brentford FC Analytics & AI Coach — Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual API keys
# DO NOT commit .env to version control!

# ============================================================================
# LLM Configuration
# ============================================================================

# Groq LLM (for original assistant_coach module)
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# xAI Grok (for assistant_coach_langchain module - DEPRECATED due to rate limits)
# Get your free API key at: https://console.x.ai
# XAI_API_KEY=xai-your_xai_api_key_here

# NVIDIA NIM (for assistant_coach_langchain module - RECOMMENDED)
# Get your free API key at: https://build.nvidia.com
# Free tier: 5000 API credits (1000 on signup + 4000 with business email)
NVIDIA_API_KEY=your_nvidia_api_key_here

# ============================================================================
# External APIs (OPTIONAL - for enhanced features)
# ============================================================================

# API-Football (for live injury data)
# Get your free API key at: https://api-sports.io
APIFOOTBALL_KEY=your_api_football_key_here
FOOTBALLDATA_KEY=your_footballdata_key_here

# Tavily Search (for latest news and fixture data)
# Get your free API key at: https://tavily.com
TAVILY_KEY=your_tavily_key_here

# ============================================================================
# Application Configuration (OPTIONAL)
# ============================================================================

# Dashboard Configuration
DASH_PORT=8050
DASH_DEBUG=True

# Streamlit Configuration
STREAMLIT_PORT=8501

# ============================================================================
# Data Configuration (OPTIONAL)
# ============================================================================

# Centralized data folder (all modules load from here)
DATA_PATH=data/brentford_2021_2026.csv

# Module-specific paths (all point to centralized data folder)
DASHBOARD_CSV_PATH=data/brentford_2021_2026.csv
ASSISTANT_COACH_CSV_PATH=data/brentford_2021_2026.csv

# ============================================================================
# Logging Configuration (OPTIONAL)
# ============================================================================
LOG_LEVEL=INFO

# ============================================================================
# Module Guide
# ============================================================================
# 
# 1. Dashboard (dashboard/app.py)
#    - No API keys required
#    - Uses: DASHBOARD_CSV_PATH
#    - Run: uv run python dashboard/app.py
#
# 2. Original AI Coach (assistant_coach/app.py)
#    - Required: GROQ_API_KEY
#    - Optional: APIFOOTBALL_KEY, TAVILY_KEY
#    - Uses: ASSISTANT_COACH_CSV_PATH
#    - Run: uv run streamlit run assistant_coach/app.py
#
# 3. LangChain AI Coach (assistant_coach_langchain/app.py)
#    - Required: NVIDIA_API_KEY (recommended) or XAI_API_KEY
#    - Optional: APIFOOTBALL_KEY, TAVILY_KEY
#    - Uses: ASSISTANT_COACH_CSV_PATH
#    - Run: uv run streamlit run assistant_coach_langchain/app.py
#
# ============================================================================
# API Key Sources
# ============================================================================
#
# Groq:         https://console.groq.com (free tier available)
# NVIDIA NIM:   https://build.nvidia.com (free tier: 5000 credits)
# xAI:          https://console.x.ai (deprecated - rate limits)
# API-Football: https://api-sports.io (free tier available)
# Tavily:       https://tavily.com (free tier available)
#
# ============================================================================
