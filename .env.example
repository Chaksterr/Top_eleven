# ============================================================================
# Brentford FC Analytics & AI Coach — Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual API keys
# DO NOT commit .env to version control!

# ============================================================================
# Groq LLM Configuration (REQUIRED for AI Coach)
# ============================================================================
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ============================================================================
# API-Football Configuration (OPTIONAL for AI Coach)
# ============================================================================
# Get your free API key at: https://api-sports.io
APIFOOTBALL_KEY=your_api_football_key_here
FOOTBALLDATA_KEY=your_footballdata_key_here

# ============================================================================
# Tavily Search Configuration (OPTIONAL for AI Coach)
# ============================================================================
# Get your free API key at: https://tavily.com
TAVILY_KEY=your_tavily_api_key_here

# ============================================================================
# Dashboard Configuration (OPTIONAL)
# ============================================================================
DASH_PORT=8050
DASH_DEBUG=True

# ============================================================================
# Streamlit Configuration (OPTIONAL)
# ============================================================================
STREAMLIT_PORT=8501

# ============================================================================
# Data Configuration (OPTIONAL)
# ============================================================================
DATA_PATH=brentford_2021_2026.csv

# ============================================================================
# Logging Configuration (OPTIONAL)
# ============================================================================
LOG_LEVEL=INFO
